<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- Title Section -->
    <TextView
        android:id="@+id/tvDetailName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:text="Chocolate Cake"
        android:textColor="@color/black"
        android:textSize="26sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Description Section -->
    <LinearLayout
        android:id="@+id/llDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="40dp"
        app:layout_constraintTop_toBottomOf="@id/tvDetailName">

        <View
            android:layout_width="60dp"
            android:layout_height="2dp"
            android:background="@color/pink_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:letterSpacing="0.2"
            android:text="DESCRIPTION"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:textStyle="bold" />

        <View
            android:layout_width="60dp"
            android:layout_height="2dp"
            android:background="@color/pink_primary" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvDetailDesc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="40dp"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:text="Savor the essence of pure cocoa with a Chocolate Cake. Each bite is an exquisite journey of rich, moist chocolate layers, blanketed in velvety ganache. The perfect choice to sweeten your special moments."
        android:textColor="@color/black"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/llDescription" />

    <!-- Size Section -->
    <LinearLayout
        android:id="@+id/llSize"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="40dp"
        app:layout_constraintTop_toBottomOf="@id/tvDetailDesc">

        <View
            android:layout_width="60dp"
            android:layout_height="2dp"
            android:background="@color/pink_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:letterSpacing="0.2"
            android:text="SIZE"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:textStyle="bold" />

        <View
            android:layout_width="60dp"
            android:layout_height="2dp"
            android:background="@color/pink_primary" />
    </LinearLayout>

    <!-- Arc Selection Mockup -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/arcContainer"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <View
            android:id="@+id/mainArc"
            android:layout_width="320dp"
            android:layout_height="320dp"
            android:layout_marginBottom="-160dp"
            android:background="@drawable/semi_circle_bg"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvPriceDetail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="110dp"
            android:text="KSH 2700"
            android:textColor="@color/black"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <Button
            android:id="@+id/btnAddToCart"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginBottom="60dp"
            android:backgroundTint="@color/white"
            android:text="Add to Cart"
            android:textAllCaps="false"
            android:textColor="@color/black"
            android:textSize="14sp"
            app:cornerRadius="20dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:strokeColor="@color/pink_primary"
            app:strokeWidth="1dp" />

        <Button
            android:id="@+id/btnBuyNow"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginHorizontal="40dp"
            android:layout_marginBottom="16dp"
            android:backgroundTint="@color/pink_primary"
            android:text="Buy Now"
            android:textAllCaps="false"
            android:textColor="@color/black"
            android:textSize="18sp"
            app:cornerRadius="25dp"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Size indicators -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0.5kg"
            android:textSize="12sp"
            android:background="@drawable/circle_white_bg"
            android:padding="8dp"
            app:layout_constraintBottom_toTopOf="@id/mainArc"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginStart="40dp"
            android:layout_marginBottom="-40dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1.5kg"
            android:textSize="12sp"
            android:background="@drawable/circle_white_bg"
            android:padding="8dp"
            app:layout_constraintBottom_toTopOf="@id/mainArc"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginBottom="-10dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2kg"
            android:textSize="12sp"
            android:background="@drawable/circle_white_bg"
            android:padding="8dp"
            app:layout_constraintBottom_toTopOf="@id/mainArc"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginEnd="40dp"
            android:layout_marginBottom="-40dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>